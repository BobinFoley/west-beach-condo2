---
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#073b4c" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/donnas-hero.webp" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Donna's Delight home"><span class="mark">DD</span><span><strong>Donna’s Delight</strong><small>JUST BEACHY · GULF SHORES</small></span></a>
      <nav aria-label="Main navigation">
        <a href="/#condo">The condo</a>
        <a href="/#amenities">Amenities</a>
        <a href="/#location">Location</a>
        <a href="/gulf-shores">Gulf Shores</a>
        <a href="/orange-beach">Orange Beach</a>
      </nav>
      <a class="nav-button" href="/#book">Check availability</a>
    </header>

    <slot />

    <footer>
      <a class="brand footer-brand" href="/"><span class="mark">DD</span><span><strong>Donna’s Delight</strong><small>WEST BEACH · GULF SHORES</small></span></a>
      <p>Made for easy mornings, long beach days, and slow sunsets.</p>
      <p>© {new Date().getFullYear()} Donna’s Delight</p>
    </footer>
  </body>
</html>

<style is:global>
  :root{--navy:#123b50;--navy-deep:#11384d;--teal:#278e97;--aqua:#78cbd0;--cream:#f7f1e7;--white:#fff;--coral:#ef7962;--ink:#183b4d;--line:#d9ddd9}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;color:var(--ink);background:#fff;font-family:'DM Sans',sans-serif;line-height:1.55}h1,h2,h3,p,figure,blockquote{margin-top:0}h1,h2,h3,blockquote{font-family:'Cormorant Garamond','Times New Roman',serif}h2{font-size:clamp(3rem,5vw,5.25rem);line-height:.91;letter-spacing:-.035em;margin-bottom:1.7rem}.kicker{text-transform:uppercase;letter-spacing:.25em;font-size:.65rem;font-weight:700;color:var(--teal);margin-bottom:1.25rem}.kicker.light{color:#e7f4f2}.site-header{height:72px;padding:0 4.5vw;display:flex;align-items:center;justify-content:space-between;gap:2rem;background:var(--cream)}.brand{display:flex;align-items:center;gap:.65rem;text-decoration:none;color:var(--navy)}.brand .mark{width:35px;height:35px;border:1px solid #83b9bb;border-radius:50%;display:grid;place-items:center;font-family:'Cormorant Garamond',serif;font-size:.72rem}.brand>span:last-child{display:flex;flex-direction:column;line-height:1}.brand strong{font-family:'Cormorant Garamond',serif;font-size:1rem}.brand small{font-size:.44rem;letter-spacing:.17em;margin-top:.28rem}.site-header nav{display:flex;gap:2.3rem}.site-header nav a{color:var(--navy);text-decoration:none;font-size:.77rem;font-weight:700}.nav-button,.coral-button{background:var(--navy-deep);color:white;text-decoration:none;padding:.8rem 1.25rem;font-size:.72rem;font-weight:700}.hero{position:relative;height:650px;color:white;overflow:hidden}.hero>img,.pool>img{position:absolute;width:100%;height:100%;object-fit:cover}.hero-shade{position:absolute;inset:0;background:linear-gradient(90deg,rgba(6,27,38,.77) 0%,rgba(6,27,38,.4) 44%,rgba(6,27,38,.05) 75%)}.hero-copy{position:absolute;left:8.2vw;top:50%;transform:translateY(-51%);max-width:570px}.hero h1{font-size:clamp(4.7rem,7.6vw,7.5rem);font-weight:500;line-height:.82;letter-spacing:-.045em;margin-bottom:1.4rem}.hero-copy>p:not(.kicker){max-width:510px;font-size:.93rem}.hero-actions{display:flex;align-items:center;gap:2rem;margin-top:2rem}.coral-button{background:var(--coral);padding:1rem 1.4rem}.hero-actions>a:last-child{color:#fff;text-decoration:none;font-size:.76rem;font-weight:600}.hero-actions span{margin-left:.5rem}.facts{position:absolute;right:0;bottom:0;width:33%;min-width:440px;height:86px;background:#fff;color:var(--navy);display:grid;grid-template-columns:repeat(4,1fr);padding:1.4rem 1.6rem}.facts div{border-right:1px solid var(--line);display:flex;flex-direction:column;align-items:center}.facts div:last-child{border:0}.facts strong{font-family:'Cormorant Garamond',serif;font-size:1.35rem;line-height:1}.facts span{text-transform:uppercase;font-size:.45rem;letter-spacing:.17em;margin-top:.45rem}.welcome{background:var(--cream);padding:7.5rem 9vw;display:grid;grid-template-columns:.9fr 1.1fr;gap:9vw;align-items:center}.welcome-copy>p:not(.kicker){max-width:560px;font-size:.9rem}.welcome address{font-style:normal;font-size:.67rem;font-weight:700;border-left:3px solid var(--coral);padding-left:.9rem;margin-top:2rem}.welcome figure{position:relative;margin:0}.welcome figure img{width:100%;display:block;aspect-ratio:1.28;object-fit:cover}.welcome figcaption{position:absolute;left:0;bottom:0;background:var(--navy);color:white;padding:1rem 1.4rem;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem}.amenities{padding:7.5rem 9vw 6.5rem}.section-intro{max-width:650px}.section-intro>p:last-child{max-width:600px;font-size:.9rem}.amenity-grid{margin-top:3rem;border:1px solid var(--line);display:grid;grid-template-columns:repeat(3,1fr)}.amenity-grid article{padding:2.2rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);min-height:180px}.amenity-grid article:nth-child(3n){border-right:0}.amenity-grid article:nth-child(n+4){border-bottom:0}.amenity-grid span{color:var(--coral);font-size:.58rem}.amenity-grid h3{font-size:1.5rem;margin:1.2rem 0 .6rem}.amenity-grid p{font-size:.7rem;color:#526a74}.pool{height:540px;position:relative;color:white;display:flex;align-items:flex-end;padding:0 8vw 4.5rem}.pool-shade{position:absolute;inset:0;background:linear-gradient(0deg,rgba(5,31,43,.76),rgba(5,31,43,0) 68%)}.pool>div:last-child{position:relative}.pool h2{color:#fff;margin-bottom:1rem}.pool p:last-child{font-size:.82rem;max-width:510px}.location{background:var(--cream);padding:7rem 9vw 7.5rem}.location-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:4vw;align-items:center}.map{height:365px;position:relative;overflow:hidden;border:7px solid #fff;background:#cfe7da;box-shadow:0 10px 26px #23404a18}.water{position:absolute;left:0;right:0;bottom:0;height:44%;background:#65bec8;color:#dff3f1;display:flex;align-items:flex-end;justify-content:center;padding-bottom:2rem;font-size:.58rem;letter-spacing:.28em}.shore{position:absolute;left:-2%;right:-2%;bottom:40%;height:54px;background:#f3dfad;transform:rotate(-2deg)}.road{position:absolute;left:-5%;right:-5%;bottom:53%;height:14px;background:#fdfcf7;border-top:2px solid #d8d3c5;border-bottom:2px solid #d8d3c5;transform:rotate(-1deg)}.pin{position:absolute;left:52%;bottom:57%;color:var(--coral);font-size:2rem;text-align:center}.pin span{display:block;color:var(--navy);background:#fff;padding:.35rem .55rem;font-size:.55rem;font-weight:700;white-space:nowrap;box-shadow:0 4px 12px #0002}.nearby>div{display:flex;justify-content:space-between;gap:2rem;padding:1rem 0;border-bottom:1px solid #d8d3c8}.nearby span{display:flex;flex-direction:column}.nearby strong{font-family:'Cormorant Garamond',serif;font-size:1.2rem}.nearby small{font-size:.64rem}.nearby b{font-size:.55rem;color:var(--teal);text-transform:uppercase;letter-spacing:.12em;white-space:nowrap}.testimonial{background:var(--navy);color:white;text-align:center;padding:6.5rem 20vw}.stars{color:#e8bd4a;letter-spacing:.16em;margin-bottom:1.6rem}.testimonial blockquote{font-size:clamp(2.2rem,4vw,4rem);font-style:italic;line-height:1.04;margin-bottom:1.5rem}.testimonial cite{text-transform:uppercase;letter-spacing:.22em;font-style:normal;font-size:.48rem}.booking{background:var(--teal);color:white;padding:5rem 9vw;display:grid;grid-template-columns:1.15fr .85fr;gap:8vw;align-items:center}.booking h2{color:white}.booking>div>p:last-child{font-size:.78rem;max-width:520px}.booking form{background:var(--cream);padding:1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:.9rem;color:var(--navy)}.booking label{font-size:.5rem;text-transform:uppercase;letter-spacing:.13em;font-weight:700}.booking input,.booking select{display:block;width:100%;height:40px;margin-top:.3rem;border:1px solid #e2ddd2;background:white;padding:0 .6rem;color:var(--ink)}.booking button{grid-column:1/-1;border:0;background:var(--coral);color:white;height:43px;font-weight:700;cursor:pointer}.booking form small{grid-column:1/-1;text-align:center;font-size:.53rem;color:#738087}footer{height:100px;background:var(--navy-deep);color:#d9e7e8;padding:0 4.5vw;display:flex;align-items:center;justify-content:space-between;font-size:.55rem}.footer-brand{color:#fff}.footer-brand .mark{border-color:#5f8c96}
  @media(max-width:850px){.site-header nav{display:none}.hero{height:680px}.facts{min-width:0;width:100%}.welcome,.location-grid,.booking{grid-template-columns:1fr}.welcome{gap:4rem}.amenity-grid{grid-template-columns:1fr 1fr}.amenity-grid article:nth-child(3n){border-right:1px solid var(--line)}.amenity-grid article:nth-child(2n){border-right:0}.amenity-grid article:nth-child(n+4){border-bottom:1px solid var(--line)}.amenity-grid article:nth-last-child(-n+2){border-bottom:0}.testimonial{padding-left:10vw;padding-right:10vw}.booking{gap:3rem}}
  @media(max-width:560px){.site-header{height:68px;padding:0 5vw}.site-header .nav-button{display:none}.hero{height:670px}.hero-copy{left:7vw;right:7vw;top:45%}.hero h1{font-size:4rem}.facts{height:78px;padding:1.2rem .5rem}.welcome,.amenities,.location{padding:5rem 7vw}.amenity-grid{grid-template-columns:1fr}.amenity-grid article{border-right:0!important;border-bottom:1px solid var(--line)!important}.amenity-grid article:last-child{border-bottom:0!important}.pool{height:480px;padding-left:7vw;padding-right:7vw}.location-grid{gap:3rem}.map{height:290px}.testimonial{padding:5rem 8vw}.booking{padding:5rem 7vw}.booking form{grid-template-columns:1fr}.booking button,.booking form small{grid-column:auto}footer{height:auto;padding:2rem 5vw;flex-direction:column;gap:1.2rem;text-align:center}}
</style>
